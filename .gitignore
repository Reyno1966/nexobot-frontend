# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NO subir valores reales a git
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# .env.example SÍ se puede subir (no tiene valores reales)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# carpeta duplicada interna
/nexobot-frontend

# archivos grandes que no deben subirse a GitHub
*.zip
*.tar.gz

# Claude Code — nunca subir al repo
.claude/
